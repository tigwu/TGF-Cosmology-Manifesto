# Conceptual Model: Flux -> Matter -> Exhaust

def compute_galactic_cycle(phi_density, viscosity_eta):
    # 1. VISCOUS DRAG (The Dark Matter Substitute)
    # The viscosity eta stabilizes the rotation curve
    velocity = apply_viscous_flow(phi_density, viscosity_eta)
    
    # 2. PHASE TRANSITION (The Birth of Stars)
    # High pressure in spiral arms triggers condensation
    if phi_density > CRITICAL_THRESHOLD:
        baryonic_matter = precipitate_matter(phi_density)
        update_visuals("Spiral_Arms_Glowing")
        
    # 3. POLAR RECYCLING (The Sink effect)
    # Excess flow and old matter are processed by the central Sink
    if is_central_sink():
        eject_polar_outflow("Fermi_Bubbles")
        recycle_to_lower_circuit()

    return velocity, baryonic_matter
